{
  "_comment": "Plugin-format hooks for sb. Claude Code resolves ${CLAUDE_PLUGIN_ROOT} to this skill's root when loaded as a plugin, so /plugin install wires capture without needing install.sh. Mirrors settings-snippet.json (the manual/symlink-install path). Do NOT run both install methods — hooks would double-register. All hooks honor SB_DISABLE=1 and fail open.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sb-session-start.js\"", "timeout": 5 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sb-capture.js\"", "timeout": 10 }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sb-capture.js\"", "timeout": 10 }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sb-capture.js\"", "timeout": 10 }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sb-session-end.js\"", "timeout": 15 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sb-prompt-watch.js\"", "timeout": 3 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sb-plan-mirror.js\"", "timeout": 5 },
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/sb-validate.js\"", "timeout": 5 }
        ]
      }
    ]
  }
}
